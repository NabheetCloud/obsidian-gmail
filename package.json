{
  "name": "obsidian-gmail-mailbox",
  "version": "0.1.0",
  "description": "Sync Gmail mail and Google Calendar into your Obsidian vault as one note per email plus a per-label thread index and an upcoming-meetings sidebar.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "install:vault": "node scripts/install.mjs"
  },
  "keywords": [
    "obsidian",
    "gmail",
    "google",
    "email",
    "calendar"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/turndown": "^5.0.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.5.7",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "turndown": "^7.1.2"
  }
}
